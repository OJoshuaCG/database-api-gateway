# ======= Application variables ======= #
APP_ENV=development # or production
APP_NAME="FastAPI Project"
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key())"
SECRET_KEY=super_secret_key


# ======= Logger variables ======= #
LOGGER_LEVEL=INFO
LOGGER_MIDDLEWARE_ENABLED=True
LOGGER_MIDDLEWARE_SHOW_HEADERS=False
LOGGER_MIDDLEWARE_SHOW_QUERY_PARAMS=True
LOGGER_MIDDLEWARE_SHOW_BODY=True
LOGGER_MIDDLEWARE_SHOW_PATH_PARAMS=True
LOGGER_EXCEPTIONS_ENABLED=False
# Si True, suprime logs de solicitudes normales (2xx/3xx).
# Ante cualquier error (4xx/5xx) siempre registra: REQUEST → ERROR → RESPONSE.
LOGGER_MIDDLEWARE_ERRORS_ONLY=False

# ======= Docs variables ======= #
DOCS_ENABLED=True
# Si True, /docs /redoc y /openapi.json requieren usuario y contraseña (HTTP Basic Auth)
DOCS_PASSWORD_ENABLED=False
DOCS_USER=admin
DOCS_PASSWORD=changeme

# ======= Rate limiting variables ======= #
# Formato: {cantidad}/{unidad} — unidades: second, minute, hour, day
# Ejemplos: 10/second, 100/minute, 1000/hour
RATE_LIMIT_DEFAULT=100/minute
# Si True, los contadores se almacenan en Redis (compartido entre workers).
# Si False, se almacenan en memoria del proceso (default, sin dependencias externas).
RATE_LIMIT_REDIS_ENABLED=False
RATE_LIMIT_REDIS_URL=redis://localhost:6379

# ======= Pagination variables ======= #
# Máximo de elementos permitidos por página. Hard cap en código: 200.
# Si este valor supera 200, se ignora y se usa 200.
PAGINATION_MAX_SIZE=50

# ======= Request size variables ======= #
# Tamaño máximo permitido del cuerpo de la solicitud en megabytes.
# Aplica a POST, PUT y PATCH. Rutas excluidas se configuran en código.
REQUEST_MAX_SIZE_MB=10

# ======= CORS variables ======= #
# Origenes permitidos separados por coma.
# La auth es por COOKIE de sesion: con "*" las credenciales NO viajan (se desactiva
# allow_credentials para no exponer la sesion cross-origin). En PRODUCCION "*" esta
# PROHIBIDO (la app aborta el arranque): define origenes especificos.
# Ej: CORS_ORIGINS=https://panel.midominio.com,https://admin.midominio.com
CORS_ORIGINS=*


# ======= Database variables ======= #
# Base de datos de METADATOS del gateway (inventario). Usar MySQL/MariaDB.
# En Docker, DB_HOST=db y DB_ENGINE=mysql+pymysql se sobrescriben en docker-compose.yml.
DB_HOST=localhost
DB_USER=username
DB_PASS=password
DB_NAME=database
DB_PORT=3306
DB_ENGINE=sqlite # or mysql+pymysql or postgresql+psycopg
# Contraseña root de la MariaDB de metadatos. OBLIGATORIA en Docker (la exige
# docker-compose.yml para inicializar el servicio `db`).
DB_ROOT_PASS=

# ======= Motores DESTINO de prueba (perfil "test" de Docker) ======= #
# Solo se usan con `docker compose --profile test up`. NO son la BD de metadatos:
# son servidores que el gateway ADMINISTRA. Tras levantarlos, regístralos vía
# POST /api/v1/servers (ver docs/docker-deployment.md).
TARGET_MARIADB_ROOT_PASS=         # root del contenedor target-mariadb (solo localhost)
TARGET_MARIADB_GW_PASS=           # admin gw_admin@'%' que el gateway usará como pseudo-root
TARGET_POSTGRES_PASSWORD=         # superusuario postgres del contenedor target-postgres

# ======= Crypto variables ======= #
# Sal NO secreta para derivar la clave Fernet desde SECRET_KEY (HKDF).
# Cambiarla invalida los secretos ya cifrados (credenciales de servidores).
# DEBE ser ÚNICA por despliegue: no reutilices el valor de ejemplo en producción.
CRYPTO_KEY_SALT=db-gateway-static-salt

# ======= Remote server connection variables ======= #
# Conexión a los servidores de BD DESTINO administrados por el gateway.
REMOTE_CONNECT_TIMEOUT=10
REMOTE_STATEMENT_TIMEOUT_MS=15000
# Política TLS hacia los motores destino (la credencial pseudo-root viaja por aquí).
# Vacío/"disable" = sin TLS. RECOMENDADO en producción:
#   PostgreSQL: require | verify-ca | verify-full
#   MySQL/MariaDB: require (cifra el transporte; verificación de CA aún no modelada)
REMOTE_SSL_MODE=

# ======= Snapshot selectivo: guardrails de datos-semilla ======= #
# El snapshot puede incluir OPCIONALMENTE datos de tablas de catálogo (opt-in por tabla)
# como INSERT idempotente. NO es ETL: estos topes protegen la BD de metadatos y la memoria
# del gateway. Hay techos DUROS en código que estas variables no pueden exceder.
SNAPSHOT_DATA_MAX_ROWS_PER_TABLE=1000
SNAPSHOT_DATA_MAX_BYTES_PER_TABLE=1048576
SNAPSHOT_DATA_MAX_TABLES=25
SNAPSHOT_DATA_BATCH_ROWS=500
# Tope de SQL por versión generada (estructura o datos). 4 MB por defecto.
SNAPSHOT_MAX_SQL_PER_VERSION=4194304

# ======= Diff estructural entre BDs (schema comparisons) ======= #
# Vida útil (horas) de una comparación persistida. Tras expirar, adopt/execute exigen recalcular.
SCHEMA_COMPARISON_TTL_HOURS=24
# Tope de sentencias por comparación (422 si se excede: dos BDs no comparables / drift masivo).
SCHEMA_COMPARISON_MAX_ITEMS=2000
# Tope de bytes del DDL total renderizado de una comparación. 8 MB por defecto.
SCHEMA_COMPARISON_MAX_SQL_BYTES=8388608

# ======= Clonado de bases de datos (database clones) ======= #
# Vida útil (horas) de un plan de clonación. Tras expirar, execute exige replanear.
CLONE_TTL_HOURS=24
# Workers del pool in-process que ejecutan los jobs de clonación en segundo plano.
# NO es una cola durable: si el proceso se reinicia, los jobs en curso quedan 'interrupted'.
CLONE_MAX_WORKERS=2
# Filas por lote en la copia de datos por streaming (lectura yield_per + escritura executemany).
CLONE_DATA_BATCH_ROWS=1000

# ======= Admin / Session variables ======= #
# Administrador único del gateway. Se siembra al arrancar si no existe.
# ADMIN_PASSWORD es OBLIGATORIO en producción.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Secreto para firmar la cookie de sesión. Si vacío, se deriva de SECRET_KEY.
# En PRODUCCIÓN es OBLIGATORIO y debe ser DIFERENTE de SECRET_KEY (el arranque aborta si falta).
SESSION_SECRET=
# Duración de la sesión en segundos (default 8h = 28800).
SESSION_MAX_AGE=28800
