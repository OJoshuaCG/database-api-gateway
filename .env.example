# ======= Application variables ======= #
APP_ENV=development # or production
APP_NAME="FastAPI Project"
SECRET_KEY=super_secret_key


# ======= Logger variables ======= #
LOGGER_LEVEL=INFO
LOGGER_MIDDLEWARE_ENABLED=True
LOGGER_MIDDLEWARE_SHOW_HEADERS=False
LOGGER_MIDDLEWARE_SHOW_QUERY_PARAMS=True
LOGGER_MIDDLEWARE_SHOW_BODY=True
LOGGER_MIDDLEWARE_SHOW_PATH_PARAMS=True
LOGGER_EXCEPTIONS_ENABLED=False

# ======= Docs variables ======= #
DOCS_ENABLED=True

# ======= Rate limiting variables ======= #
# Formato: {cantidad}/{unidad} — unidades: second, minute, hour, day
# Ejemplos: 10/second, 100/minute, 1000/hour
RATE_LIMIT_DEFAULT=100/minute

# ======= Pagination variables ======= #
# Máximo de elementos permitidos por página. Hard cap en código: 200.
# Si este valor supera 200, se ignora y se usa 200.
PAGINATION_MAX_SIZE=50

# ======= Request size variables ======= #
# Tamaño máximo permitido del cuerpo de la solicitud en megabytes.
# Aplica a POST, PUT y PATCH. Rutas excluidas se configuran en código.
REQUEST_MAX_SIZE_MB=10

# ======= CORS variables ======= #
# Origenes permitidos separados por coma. Usa * para permitir todos.
# IMPORTANTE: "*" es incompatible con allow_credentials=True en browsers.
# En produccion define origenes especificos: https://myapp.com,https://admin.myapp.com
CORS_ORIGINS=*


# ======= Database variables ======= #
DB_HOST=localhost
DB_USER=username
DB_PASS=password
DB_NAME=database
DB_PORT=3306
DB_ENGINE=sqlite # or mysql+pymysql or postgresql+psycopg2
