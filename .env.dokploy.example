# =============================================================================
# Plantilla de variables para DESPLIEGUE EN DOKPLOY
#
# No se commitea con valores reales. Copia este contenido y pégalo (con los
# valores reales completados) en la pestaña "Environment" del proyecto Compose
# en el panel de Dokploy. Ver docs/dokploy-deployment.md para la guía completa.
#
# Valores marcados [CAMBIAR] son obligatorios de cambiar antes de producción.
# DB_HOST=db, DB_ENGINE=mysql+pymysql y RATE_LIMIT_REDIS_* se sobrescriben en
# docker-compose.dokploy.yml: NO hace falta (ni sirve) editarlos aquí.
# =============================================================================

# ======= Application ======= #
APP_ENV=production
APP_NAME="Database API Gateway"
# Generar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# [CAMBIAR]
SECRET_KEY=CHANGE_ME_generate_a_real_key

# ======= Logger ======= #
LOGGER_LEVEL=INFO
LOGGER_MIDDLEWARE_ENABLED=True
LOGGER_MIDDLEWARE_SHOW_HEADERS=False
LOGGER_MIDDLEWARE_SHOW_QUERY_PARAMS=True
LOGGER_MIDDLEWARE_SHOW_BODY=False
LOGGER_MIDDLEWARE_SHOW_PATH_PARAMS=True
LOGGER_EXCEPTIONS_ENABLED=True
LOGGER_MIDDLEWARE_ERRORS_ONLY=False

# ======= Docs ======= #
# en producción: False, o protegido con DOCS_PASSWORD_ENABLED
DOCS_ENABLED=False
DOCS_PASSWORD_ENABLED=False
DOCS_USER=admin
DOCS_PASSWORD=changeme

# ======= Rate limiting ======= #
RATE_LIMIT_DEFAULT=100/minute
# docker-compose.dokploy.yml fuerza RATE_LIMIT_REDIS_ENABLED=True apuntando al
# servicio `valkey` (fork OSI de Redis, wire-compatible). Estos valores son fallback.
RATE_LIMIT_REDIS_ENABLED=False
RATE_LIMIT_REDIS_URL=redis://localhost:6379

# ======= Anti-SSRF (host de servidores destino) ======= #
# True (default): rechaza destinos peligrosos (loopback, link-local/metadata, etc.).
REMOTE_SSRF_GUARD_ENABLED=True
# Allowlist OPCIONAL de CIDRs (vacío = solo denylist). Ej: 10.0.0.0/8,192.168.0.0/16
REMOTE_ALLOWED_CIDRS=

# ======= Pagination / Request size ======= #
PAGINATION_MAX_SIZE=50
REQUEST_MAX_SIZE_MB=10

# ======= CORS ======= #
# En producción PROHIBIDO "*" (la app aborta el arranque): usa orígenes explícitos.
# [CAMBIAR]
CORS_ORIGINS=https://tu-dominio-frontend.com

# ======= Base de datos de METADATOS (servicio `db`, MariaDB) ======= #
# Es la BD principal donde corren las migraciones de Alembic al arrancar.
DB_USER=gateway
# [CAMBIAR]
DB_PASS=changeme_db_pass
DB_NAME=gateway_metadata
DB_PORT=3306
# [CAMBIAR] — exigida por docker-compose.dokploy.yml para crear `db`
DB_ROOT_PASS=changeme_root_pass
# DB_HOST y DB_ENGINE se sobrescriben en docker-compose.dokploy.yml.
DB_HOST=db
DB_ENGINE=mysql+pymysql

# ======= Crypto ======= #
# Sal NO secreta para derivar la clave Fernet desde SECRET_KEY (HKDF).
# Cambiarla invalida las credenciales de servidores ya cifradas.
# [CAMBIAR] — sal única por despliegue
CRYPTO_KEY_SALT=CHANGE_ME_unique_salt_per_deployment

# ======= Conexión a servidores DESTINO ======= #
REMOTE_CONNECT_TIMEOUT=10
REMOTE_STATEMENT_TIMEOUT_MS=15000
# TLS por DEFECTO hacia los motores destino. Es solo un FALLBACK: el TLS real se
# define POR SERVIDOR (campo ssl_mode al registrar/editar el Server). Si un servidor
# no define ssl_mode, se usa este valor; vacío = sin TLS (se omite el paso).
# Valores: require | verify-ca | verify-full (PostgreSQL admite además prefer/allow/disable).
REMOTE_SSL_MODE=

# ======= Admin / Session ======= #
ADMIN_USERNAME=admin
# [CAMBIAR] — obligatorio en producción
ADMIN_PASSWORD=changeme_admin
# Firma de la cookie de sesión. Debe ser independiente de SECRET_KEY en producción.
# [CAMBIAR] — debe ser independiente de SECRET_KEY
SESSION_SECRET=CHANGE_ME_session_secret
SESSION_MAX_AGE=28800
# Con APP_ENV=production (arriba) la cookie de sesión exige HTTPS por defecto (flag
# Secure). Deja esta variable vacía/comentada una vez que el dominio tenga HTTPS
# habilitado en la pestaña Domains de Dokploy (ver docs/dokploy-deployment.md).
# Solo como diagnóstico TEMPORAL mientras se termina de configurar el dominio, se
# puede descomentar SESSION_COOKIE_SECURE=False — NO dejarlo así en producción real,
# la cookie viajaría sin cifrar.
# SESSION_COOKIE_SECURE=False

# ======= Escalado ======= #
# Workers de Uvicorn dentro del contenedor `api` (docker/scripts/entrypoint.sh).
# Con RATE_LIMIT_REDIS_ENABLED=True (forzado arriba) el rate limiting ya está
# compartido, así que se puede subir de 1 sin perder consistencia entre workers.
WORKERS=1

# =============================================================================
# Notas para PRODUCCIÓN:
#   - SECRET_KEY, SESSION_SECRET y CRYPTO_KEY_SALT reales, únicos y distintos entre sí.
#   - CORS_ORIGINS con dominios exactos (no "*"): la app se niega a arrancar si lo es.
#   - ADMIN_PASSWORD definido: la app se niega a arrancar en producción si falta.
#   - DOCS_ENABLED=False o protegido con DOCS_PASSWORD_ENABLED.
#   - Contraseñas fuertes en DB_*. TLS hacia cada motor destino vía su ssl_mode
#     (require como mínimo); REMOTE_SSL_MODE como fallback global.
#   - Los motores destino de PRUEBA (target-mariadb/target-postgres, perfil "test"
#     de docker-compose.yml) NO forman parte de este despliegue: no se incluyen en
#     docker-compose.dokploy.yml a propósito.
# =============================================================================
