# =============================================================================
# Plantilla de variables para DESPLIEGUE/PRUEBA EN DOCKER
#   cp .env.docker.example .env
#   docker compose up -d --build                 # gateway + MariaDB metadatos + nginx
#   docker compose --profile test up -d --build  # + motores destino de prueba
#
# Valores marcados [CAMBIAR] son obligatorios de cambiar antes de producción.
# DB_HOST=db y DB_ENGINE=mysql+pymysql se inyectan en docker-compose.yml: NO editarlos aquí.
# =============================================================================

# ======= Application ======= #
APP_ENV=development            # cambiar a "production" para endurecer (ver notas al final)
APP_NAME="Database API Gateway"
# Generar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=CHANGE_ME_generate_a_real_key   # [CAMBIAR]

# ======= Logger ======= #
LOGGER_LEVEL=INFO
LOGGER_MIDDLEWARE_ENABLED=True
LOGGER_MIDDLEWARE_SHOW_HEADERS=False
LOGGER_MIDDLEWARE_SHOW_QUERY_PARAMS=True
LOGGER_MIDDLEWARE_SHOW_BODY=False
LOGGER_MIDDLEWARE_SHOW_PATH_PARAMS=True
LOGGER_EXCEPTIONS_ENABLED=True
LOGGER_MIDDLEWARE_ERRORS_ONLY=False

# ======= Docs ======= #
DOCS_ENABLED=True              # en producción: False, o protegido con DOCS_PASSWORD_ENABLED
DOCS_PASSWORD_ENABLED=False
DOCS_USER=admin
DOCS_PASSWORD=changeme

# ======= Rate limiting ======= #
RATE_LIMIT_DEFAULT=100/minute
# En Docker, docker-compose.yml fuerza RATE_LIMIT_REDIS_ENABLED=True y apunta al
# servicio `valkey` (fork OSI de Redis, wire-compatible). Estos valores son fallback.
RATE_LIMIT_REDIS_ENABLED=False
RATE_LIMIT_REDIS_URL=redis://localhost:6379

# ======= Anti-SSRF (host de servidores destino) ======= #
# True (default): rechaza destinos peligrosos (loopback, link-local/metadata, etc.).
REMOTE_SSRF_GUARD_ENABLED=True
# Allowlist OPCIONAL de CIDRs (vacío = solo denylist). Ej: 10.0.0.0/8,192.168.0.0/16
REMOTE_ALLOWED_CIDRS=

# ======= Pagination / Request size ======= #
PAGINATION_MAX_SIZE=50
REQUEST_MAX_SIZE_MB=10

# ======= CORS ======= #
# En producción PROHIBIDO "*" (la app aborta): usa orígenes explícitos.
CORS_ORIGINS=*                 # [CAMBIAR en producción]

# ======= Base de datos de METADATOS (servicio `db`, MariaDB) ======= #
# Es la BD principal donde corren las migraciones de Alembic al arrancar.
DB_USER=gateway
DB_PASS=changeme_db_pass        # [CAMBIAR]
DB_NAME=gateway_metadata
DB_PORT=3306
DB_ROOT_PASS=changeme_root_pass # [CAMBIAR] — exigida por docker-compose.yml para crear `db`
# DB_HOST y DB_ENGINE se sobrescriben en docker-compose.yml (db / mysql+pymysql).
DB_HOST=db
DB_ENGINE=mysql+pymysql

# ======= Crypto ======= #
# Sal NO secreta para derivar la clave Fernet desde SECRET_KEY (HKDF).
# Cambiarla invalida las credenciales de servidores ya cifradas.
CRYPTO_KEY_SALT=db-gateway-static-salt

# ======= Conexión a servidores DESTINO ======= #
REMOTE_CONNECT_TIMEOUT=10
REMOTE_STATEMENT_TIMEOUT_MS=15000
# TLS por DEFECTO hacia los motores destino. Es solo un FALLBACK: el TLS real se
# define POR SERVIDOR (campo ssl_mode al registrar/editar el Server). Si un servidor
# no define ssl_mode, se usa este valor; vacío = sin TLS (se omite el paso).
# Valores: require | verify-ca | verify-full (PostgreSQL admite además prefer/allow/disable).
REMOTE_SSL_MODE=

# ======= Admin / Session ======= #
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin    # [CAMBIAR] — obligatorio en producción
# Firma de la cookie de sesión. Si vacío, se deriva de SECRET_KEY.
SESSION_SECRET=
SESSION_MAX_AGE=28800

# ======= Motores DESTINO de prueba (solo perfil "test") ======= #
# Servidores que el gateway ADMINISTRA. Tras `--profile test up`, regístralos vía API:
#   MariaDB    -> engine=mariadb,    host=target-mariadb,  port=3306, root_username=gw_admin
#   PostgreSQL -> engine=postgresql, host=target-postgres, port=5432, root_username=postgres
TARGET_MARIADB_ROOT_PASS=changeme_target_root   # root del contenedor (solo localhost)
TARGET_MARIADB_GW_PASS=changeme_gw_admin        # admin gw_admin@'%' (pseudo-root del gateway)
TARGET_POSTGRES_PASSWORD=changeme_pg_pass        # superusuario postgres

# =============================================================================
# Notas para PRODUCCIÓN (APP_ENV=production):
#   - SECRET_KEY real y único; CORS_ORIGINS con dominios exactos (no "*").
#   - ADMIN_PASSWORD definido; DOCS_ENABLED=False o protegido.
#   - Contraseñas fuertes en DB_*. TLS hacia cada motor destino vía su ssl_mode
#     (require como mínimo); REMOTE_SSL_MODE como fallback global.
#   - El perfil "test" (target-*) NO debe levantarse en producción.
# =============================================================================
